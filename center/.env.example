# SuperDreams Control Center — 环境变量配置
# 复制为 .env.local 并填入实际值

# ===== JWT 密钥 =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===== Upstash Redis (生产环境持久化) =====
# 设置后 Center 自动切换到 Upstash Redis 持久化存储
# 不设置则使用本地 SQLite (better-sqlite3)
# 在 Vercel Dashboard → Storage → Redis (Upstash) 创建后获取
# 也兼容旧的 KV_REST_API_URL / KV_REST_API_TOKEN 变量名
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== 数据库路径 (仅 SQLite 模式) =====
# DATABASE_PATH=./data/center.db
