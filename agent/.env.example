# SuperDreams Agent — 环境变量配置
# 复制为 .env.local 并填入实际值

# ===== Upstash Redis (生产环境持久化) =====
# 设置后 Agent 自动切换到 Upstash Redis 持久化存储
# 不设置则使用本地 SQLite (sql.js)
# 在 Vercel Dashboard → Storage → Redis (Upstash) 创建后获取
# 也兼容旧的 KV_REST_API_URL / KV_REST_API_TOKEN 变量名
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Center 同步配置 (可选) =====
# Agent 向 Center 上报数据时的目标地址和密钥
# CENTER_URL=https://your-center.vercel.app
# CENTER_API_KEY=your-api-key
